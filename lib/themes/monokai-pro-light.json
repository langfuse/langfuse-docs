{
  "name": "Monokai Pro Light",
  "type": "light",
  "colors": {
    "editor.background": "#fafaf8",
    "editor.foreground": "#2d2a2e",
    "editor.lineHighlightBackground": "#f0ede6",
    "editor.selectionBackground": "#dedad7",
    "editor.inactiveSelectionBackground": "#e8e5e0",
    "editorLineNumber.foreground": "#b0aeae",
    "editorLineNumber.activeForeground": "#6e6d6e",
    "editorCursor.foreground": "#2d2a2e",
    "editorWhitespace.foreground": "#d1ccc8",
    "editorIndentGuide.background": "#e8e5e0",
    "editorIndentGuide.activeBackground": "#c8c5c0"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#9d9d9d",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated",
        "punctuation.definition.string.begin",
        "punctuation.definition.string.end"
      ],
      "settings": {
        "foreground": "#b58900"
      }
    },
    {
      "name": "String template expression punctuation",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#f85e84"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.octal",
        "constant.numeric.binary"
      ],
      "settings": {
        "foreground": "#9a7ee6"
      }
    },
    {
      "name": "Boolean / Null / Undefined",
      "scope": [
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#9a7ee6"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.typeof",
        "keyword.operator.void",
        "keyword.operator.in",
        "keyword.operator.of",
        "keyword.operator.instanceof",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#f85e84"
      }
    },
    {
      "name": "Storage type / modifier (const, let, var, function, class, …)",
      "scope": [
        "storage.type",
        "storage.modifier",
        "storage.type.function.arrow"
      ],
      "settings": {
        "foreground": "#f85e84"
      }
    },
    {
      "name": "Arrow operator",
      "scope": [
        "storage.type.function.arrow",
        "keyword.operator.arrow"
      ],
      "settings": {
        "foreground": "#f85e84"
      }
    },
    {
      "name": "Operator",
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#f85e84"
      }
    },
    {
      "name": "Function name (declaration)",
      "scope": [
        "entity.name.function",
        "meta.definition.method entity.name.function"
      ],
      "settings": {
        "foreground": "#78a855"
      }
    },
    {
      "name": "Function call",
      "scope": [
        "meta.function-call entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#78a855"
      }
    },
    {
      "name": "Class / Type name",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.other.inherited-class",
        "support.class"
      ],
      "settings": {
        "foreground": "#fc9867"
      }
    },
    {
      "name": "Type annotation / primitive type",
      "scope": [
        "support.type.primitive",
        "support.type.builtin",
        "keyword.type"
      ],
      "settings": {
        "foreground": "#fc9867"
      }
    },
    {
      "name": "Object property / member access",
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.property-name"
      ],
      "settings": {
        "foreground": "#2db0bf"
      }
    },
    {
      "name": "Object key",
      "scope": [
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#2db0bf"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#2d2a2e"
      }
    },
    {
      "name": "Built-in variable / this / self",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self"
      ],
      "settings": {
        "foreground": "#f85e84",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "constant.other",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#fc9867"
      }
    },
    {
      "name": "Tag name (HTML/JSX)",
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#f85e84"
      }
    },
    {
      "name": "Tag attribute",
      "scope": [
        "entity.other.attribute-name",
        "meta.tag.attributes"
      ],
      "settings": {
        "foreground": "#78a855"
      }
    },
    {
      "name": "CSS property name",
      "scope": [
        "support.type.property-name.css",
        "meta.property-name.css"
      ],
      "settings": {
        "foreground": "#2db0bf"
      }
    },
    {
      "name": "CSS value",
      "scope": [
        "support.constant.property-value.css",
        "meta.property-value.css"
      ],
      "settings": {
        "foreground": "#b58900"
      }
    },
    {
      "name": "CSS selector",
      "scope": ["entity.name.tag.css", "entity.other.attribute-name.class.css"],
      "settings": {
        "foreground": "#78a855"
      }
    },
    {
      "name": "Regexp",
      "scope": ["string.regexp", "constant.regexp"],
      "settings": {
        "foreground": "#2db0bf"
      }
    },
    {
      "name": "Import / module path",
      "scope": [
        "string.quoted.double.import",
        "string.quoted.single.import",
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.export"
      ],
      "settings": {
        "foreground": "#f85e84"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#2d2a2e"
      }
    },
    {
      "name": "Decorator / Annotation",
      "scope": ["meta.decorator", "punctuation.decorator"],
      "settings": {
        "foreground": "#78a855",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python special keywords",
      "scope": ["keyword.control.import.python", "keyword.control.flow.python"],
      "settings": {
        "foreground": "#f85e84"
      }
    },
    {
      "name": "Invalid / deprecated",
      "scope": ["invalid", "invalid.deprecated"],
      "settings": {
        "foreground": "#f85e84",
        "fontStyle": "underline"
      }
    }
  ]
}
